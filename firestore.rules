rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // usage/{uid} — one doc per user, holding their cumulative minutes.
    match /usage/{uid} {
      // A signed-in user can read only their own usage document.
      allow read: if request.auth != null && request.auth.uid == uid;

      // Nobody writes this from the client — ever. The recordUsage Cloud
      // Function uses the Admin SDK, which bypasses these rules entirely,
      // so this "allow write: if false" doesn't block the function; it
      // only blocks someone editing the value directly from dev tools.
      allow write: if false;
    }

    // userProfiles/{uid} — one doc per user, written once at registration
    // (see register.js) with the name/company collected on signup. A
    // Cloud Function (syncUserProfileToHubspot) listens for writes here
    // and pushes firstname/lastname/company to the matching HubSpot
    // contact. Kept as a create-only doc: nothing in the app currently
    // needs to edit this after signup, so update/delete are blocked to
    // keep the data trustworthy as a one-time registration record.
    match /userProfiles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['firstName', 'lastName', 'company', 'email', 'createdAt'])
        && request.resource.data.firstName is string && request.resource.data.firstName.size() > 0
        && request.resource.data.lastName is string && request.resource.data.lastName.size() > 0
        && request.resource.data.company is string && request.resource.data.company.size() > 0
        && request.resource.data.email == request.auth.token.email;

      allow update: if false;
      allow delete: if false;
    }

    match /logins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // only the recordLogin Cloud Function (Admin SDK) writes this
    }

    match /sessions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // only recordSessionTime (Admin SDK) writes this
    }
  }
}
